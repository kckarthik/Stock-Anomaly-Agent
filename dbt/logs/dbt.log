    symbol,
    sector,
    bar_time,
    bar_date,
    bar_hour,
    bar_minute,
    open,
    high,
    low,
    close,
    volume,
    tick_count,
    price_change_pct,
    dollar_volume,
    bar_range,
    processed_at
FROM "stockdb"."public"."stg_silver_bars"
  );
  
