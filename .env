# ── Kafka ────────────────────────────────────────────────────────
KAFKA_BROKER=kafka:9092
KAFKA_TOPIC=raw_quotes
KAFKA_GROUP_ID=stock-consumer-group

# ── MinIO (S3 — Bronze + Silver) ─────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false

# ── TimescaleDB (Gold + Reports) ─────────────────────────────────
TIMESCALE_HOST=timescaledb
TIMESCALE_PORT=5432
TIMESCALE_DB=stockdb
TIMESCALE_USER=stock
TIMESCALE_PASSWORD=stock123

# ── Redis (Celery) ────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Ollama (Local LLM) ───────────────────────────────────────────
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=qwen2.5:0.5b

# ── Pipeline Tuning ───────────────────────────────────────────────
POLL_INTERVAL_SECONDS=60
AGENT_SCHEDULE_MINUTES=5
CELERY_WORKERS=2

# ── Anomaly Detection Thresholds ─────────────────────────────────
VOLUME_ZSCORE_THRESHOLD=2.5
PRICE_CHANGE_THRESHOLD=2.0

# ── Agent Behaviour ───────────────────────────────────────────────
MAX_INVESTIGATION_STEPS=5
AGENT_RETRY_DELAY_SECONDS=30
AGENT_MAX_RETRIES=3

# ── Prometheus Metrics Ports ─────────────────────────────────────
PRODUCER_METRICS_PORT=8001
CONSUMER_METRICS_PORT=8002
DBT_METRICS_PORT=8003
SCHEDULER_METRICS_PORT=8004

# ── Langfuse (self-hosted LLM observability) ──────────────────────
# Step 1: Run ./start.sh — Langfuse boots at http://localhost:3002
# Step 2: Visit localhost:3002 → Sign Up (any email/password, fully local)
# Step 3: Create project "stock-agent" → Settings → API Keys → Create
# Step 4: Paste real keys below (replacing the placeholders)
# Step 5: docker compose restart celery-worker agent-scheduler
LANGFUSE_PUBLIC_KEY=pk-lf-placeholder
LANGFUSE_SECRET_KEY=sk-lf-placeholder
LANGFUSE_HOST=http://langfuse:3000